# RDAgent Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# LLM Configuration
# ==========================================

# LLM Provider: mock, litellm, openai
RD_AGENT_LLM_PROVIDER=litellm

# API Key for LLM provider (required for non-mock providers)
# Examples:
#   OpenAI: sk-...
#   Anthropic: sk-ant-...
#   Google: AIza...
RD_AGENT_LLM_API_KEY=

# Model identifier (provider-specific)
# Examples:
#   OpenAI: gpt-4o-mini, gpt-4o
#   Anthropic: claude-3-sonnet-20240229
#   Google: gemini/gemini-2.5-pro
RD_AGENT_LLM_MODEL=gpt-4o-mini

# Optional: Custom base URL for LLM provider (e.g., for Azure or proxies)
RD_AGENT_LLM_BASE_URL=

# ==========================================
# Application Configuration
# ==========================================

# Runtime environment: dev, test, production
AGENTRD_ENV=dev

# Default scenario plugin
AGENTRD_DEFAULT_SCENARIO=data_science

# Storage paths
AGENTRD_ARTIFACT_ROOT=/tmp/rd_agent_artifacts
AGENTRD_WORKSPACE_ROOT=/tmp/rd_agent_workspace
AGENTRD_TRACE_STORAGE_PATH=/tmp/rd_agent_trace/events.jsonl
AGENTRD_SQLITE_PATH=/tmp/rd_agent.sqlite3

# Execution settings
AGENTRD_SANDBOX_TIMEOUT_SEC=300
AGENTRD_ALLOW_LOCAL_EXECUTION=false
AGENTRD_LOG_LEVEL=INFO

# ==========================================
# MCTS / Exploration Settings
# ==========================================

RD_AGENT_MCTS_WEIGHT=1.41
RD_AGENT_MCTS_C_PUCT=1.41
RD_AGENT_LAYER0_N_CANDIDATES=5
RD_AGENT_LAYER0_K_FORWARD=2
RD_AGENT_PRUNE_THRESHOLD=0.5

# ==========================================
# Advanced Settings
# ==========================================

# Max reasoning rounds per step
RD_AGENT_COSTEER_MAX_ROUNDS=1

# Debug mode
AGENTRD_DEBUG_MODE=false
AGENTRD_DEBUG_SAMPLE_FRACTION=0.1
AGENTRD_DEBUG_MAX_EPOCHS=5
