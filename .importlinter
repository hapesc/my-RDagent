[importlinter]
root_packages =
    rd_agent
include_external_packages = True

[importlinter:rd_agent_core_isolation]
name = RDAgent core avoids direct V2 runtime imports
type = forbidden
source_modules =
    rd_agent.entry
    rd_agent.orchestration
forbidden_modules =
    app.control_plane
    app.query_services
    app.runtime
    core.loop
    service_contracts
    data_models
    exploration_manager

[importlinter:rd_agent_tools_are_isolated_from_legacy_runtime]
name = RDAgent tools avoid legacy runtime, query, DTO, and graph modules
type = forbidden
source_modules =
    rd_agent.tools
forbidden_modules =
    app.control_plane
    app.query_services
    app.runtime
    core.loop
    service_contracts
    data_models
    exploration_manager

