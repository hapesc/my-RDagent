[importlinter]
root_packages =
    v3
include_external_packages = True

[importlinter:v3_core_isolation]
name = V3 core avoids direct V2 runtime imports
type = forbidden
source_modules =
    v3.entry
    v3.orchestration
forbidden_modules =
    app.control_plane
    app.query_services
    app.runtime
    core.loop
    service_contracts
    data_models
    exploration_manager

[importlinter:v3_tools_are_isolated_from_legacy_runtime]
name = V3 tools avoid legacy runtime, query, DTO, and graph modules
type = forbidden
source_modules =
    v3.tools
forbidden_modules =
    app.control_plane
    app.query_services
    app.runtime
    core.loop
    service_contracts
    data_models
    exploration_manager

[importlinter:phase14_stage_write_tools_are_isolated_from_legacy_runtime]
name = Phase 14 stage write tools avoid legacy runtime, control plane, query, DTO, and graph modules
type = forbidden
source_modules =
    v3.tools.stage_write_tools
forbidden_modules =
    app.control_plane
    app.query_services
    app.runtime
    core.loop
    service_contracts
    data_models
    exploration_manager

[importlinter:v3_entry_avoids_legacy_query_and_dto_modules]
